{
  "name": "clideck",
  "version": "1.31.4",
  "description": "One screen for all your AI coding agents — run, monitor, and manage multiple CLI agents from a single browser tab",
  "main": "server.js",
  "bin": {
    "clideck": "bin/clideck.js"
  },
  "scripts": {
    "start": "node server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "build:css": "tailwindcss -i src/input.css -o public/tailwind.css --minify",
    "prepublishOnly": "npm run build:css"
  },
  "keywords": [
    "terminal",
    "cli",
    "ai",
    "agent",
    "claude",
    "codex",
    "gemini",
    "opencode",
    "dashboard",
    "multiplexer",
    "xterm"
  ],
  "author": "Or Kuntzman",
  "license": "MIT",
  "type": "commonjs",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rustykuntz/clideck.git"
  },
  "homepage": "https://clideck.dev/",
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "node-pty": "^1.1.0",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "happy-dom": "^20.9.0",
    "tailwindcss": "^3.4.19",
    "vitest": "^4.1.6"
  },
  "engines": {
    "node": ">=18"
  }
}
